import os                                                                       
import requests                                                                 
import json                                                                     
                                                                                
def get_weather(city, state_code, country_code, api_key, units='imperial'):     
    """                                                                         
    Fetches current weather data from OpenWeatherMap for a given location.      
                                                                                
    Args:                                                                       
        city (str): The name of the city.                                       
        state_code (str): The state code (for US locations).                    
        country_code (str): The two-letter country code.                        
        api_key (str): Your OpenWeatherMap API key.                             
        units (str): Units of measurement ('imperial' for Fahrenheit, 'metric'  
for Celsius).                                                                   
                                                                                
    Returns:                                                                    
        str: A formatted string of the current weather or an error message.     
    """                                                                         
    base_url = "https://api.openweathermap.org/data/2.5/weather"                
    params = {                                                                  
        "q": f"{city},{state_code},{country_code}",                             
        "appid": api_key,                                                       
        "units": units                                                          
    }                                                                           
                                                                                
    try:                                                                        
        response = requests.get(base_url, params=params)                        
        response.raise_for_status()  # Raise an HTTPError for bad responses (4xx
or 5xx)                                                                         
        data = response.json()                                                  
                                                                                
        if data.get("cod") == 200:                                              
            main_data = data.get("main", {})                                    
            weather_data = data.get("weather", [{}])[0]                         
            wind_data = data.get("wind", {})                                    
            name = data.get("name")                                             
                                                                                
            temperature = main_data.get("temp")                                 
            feels_like = main_data.get("feels_like")                            
            humidity = main_data.get("humidity")                                
            description = weather_data.get("description", "N/A").capitalize()   
            wind_speed = wind_data.get("speed")                                 
                                                                                
            weather_report = f"Current weather in {name}:\n"                    
            weather_report += f"Description: {description}\n"                   
            weather_report += f"Temperature: {temperature}°F (Feels like:       
{feels_like}°F)\n"                                                              
            weather_report += f"Humidity: {humidity}%\n"                        
            weather_report += f"Wind Speed: {wind_speed} mph\n"                 
            return weather_report                                               
        else:                                                                   
            return f"Error fetching weather: {data.get('message', 'Unknown      
error')}"                                                                       
                                                                                
    except requests.exceptions.HTTPError as http_err:                           
        return f"HTTP error occurred: {http_err}"                               
    except requests.exceptions.ConnectionError as conn_err:                     
        return f"Connection error occurred: {conn_err}"                         
    except requests.exceptions.Timeout as timeout_err:                          
        return f"Timeout error occurred: {timeout_err}"                         
    except requests.exceptions.RequestException as req_err:                     
        return f"An unexpected error occurred: {req_err}"                       
    except json.JSONDecodeError:                                                
        return "Error: Could not decode JSON response from weather API."        
                                                                                
if __name__ == "__main__":                                                      
    api_key = os.environ.get("OPENWEATHER_API_KEY")                             
    if not api_key:                                                             
        print("Error: OPENWEATHER_API_KEY environment variable not set.",       
file=os.stderr)                                                                 
        print("Please obtain a free API key from OpenWeatherMap                 
(https://openweathermap.org/api) and set it.", file=os.stderr)                  
        exit(1)                                                                 
                                                                                
    city = "Claremont"                                                          
    state_code = "CA"                                                           
    country_code = "US"                                                         
                                                                                
    weather_output = get_weather(city, state_code, country_code, api_key)       
    print(weather_output)                                                       
