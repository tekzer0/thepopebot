de}&current_weather=true&temperature_unit=fahrenheit&forecast_days=1`;          
                                                                                
  try {                                                                         
    const response = await fetch(url);                                          
    if (!response.ok) {                                                         
      throw new Error(`HTTP error! status: ${response.status}`);                
    }                                                                           
